import { useState, useEffect } from 'react'
import { fetchPlatforms, type PlatformItem } from '../services/api'
import './SectionStyles.css'

type MessageType = { type: 'success' | 'error'; text: string }

interface Props {
  username: string
}

export default function PlatformsSection({ username }: Props) {
  const [loading, setLoading] = useState(true)
  const [message, setMessage] = useState<MessageType | null>(null)
  const [platforms, setPlatforms] = useState<PlatformItem[]>([])

  useEffect(() => {
    void loadData()
  }, [])

  useEffect(() => {
    if (message) {
      const timer = setTimeout(() => setMessage(null), 5000)
      return () => clearTimeout(timer)
    }
  }, [message])

  const loadData = async () => {
    try {
      setLoading(true)
      const platformsData = await fetchPlatforms()
      setPlatforms(platformsData)
    } catch (err) {
      setMessage({ type: 'error', text: (err as Error).message })
    } finally {
      setLoading(false)
    }
  }

  if (loading) {
    return (
      <div className="content-card">
        <div className="loading-spinner"></div>
        <p>로딩 중...</p>
      </div>
    )
  }

  return (
    <div className="section-container">
      <h2>🌐 플랫폼 관리</h2>
      <p className="section-description">
        지원하는 소셜 미디어 플랫폼 목록을 확인합니다. (사용자: {username})
      </p>

      {message && (
        <div className={`message ${message.type}`}>
          {message.text}
        </div>
      )}

      {/* 플랫폼 카드 */}
      <div className="content-card">
        <h3>📱 지원 플랫폼</h3>
        {platforms.length === 0 ? (
          <p className="empty-state">등록된 플랫폼이 없습니다.</p>
        ) : (
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(300px, 1fr))', gap: '1.5rem' }}>
            {platforms.map((platform) => (
              <div
                key={platform.id}
                className="content-card"
                style={{
                  background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                  color: 'white',
                  padding: '1.5rem',
                }}
              >
                <div style={{ display: 'flex', alignItems: 'center', gap: '1rem' }}>
                  <div style={{ fontSize: '3rem' }}>
                    {platform.platform_code === 'youtube' ? '📺' : 
                     platform.platform_code === 'tiktok' ? '🎵' : 
                     platform.platform_code === 'instagram' ? '📷' :
                     platform.platform_code === 'facebook' ? '👥' : '📱'}
                  </div>
                  <div style={{ flex: 1 }}>
                    <h4 style={{ margin: 0, fontSize: '1.3rem' }}>{platform.platform_name}</h4>
                    <p style={{ margin: '0.5rem 0 0 0', opacity: 0.9, fontSize: '0.9rem' }}>
                      코드: {platform.platform_code}
                    </p>
                    <p style={{ margin: '0.5rem 0 0 0', opacity: 0.9, fontSize: '0.85rem' }}>
                      ID: {platform.id}
                    </p>
                  </div>
                </div>
                <div style={{ marginTop: '1rem', paddingTop: '1rem', borderTop: '1px solid rgba(255,255,255,0.3)' }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: '0.85rem' }}>
                    <span>✅ 영상 업로드</span>
                    <span>✅ 자동 게시</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      {/* 상세 테이블 */}
      <div className="content-card">
        <h3>📋 플랫폼 상세 정보</h3>
        <div className="table-container">
          <table className="data-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>플랫폼 코드</th>
                <th>플랫폼 이름</th>
                <th>지원 기능</th>
              </tr>
            </thead>
            <tbody>
              {platforms.map((platform) => (
                <tr key={platform.id}>
                  <td>{platform.id}</td>
                  <td>
                    <code style={{ 
                      background: '#f4f4f4', 
                      padding: '0.25rem 0.5rem', 
                      borderRadius: '4px',
                      fontFamily: 'monospace'
                    }}>
                      {platform.platform_code}
                    </code>
                  </td>
                  <td>
                    <strong>{platform.platform_name}</strong>
                  </td>
                  <td>
                    <span className="status-badge online">영상 업로드</span>
                    {' '}
                    <span className="status-badge online">자동 게시</span>
                    {' '}
                    <span className="status-badge online">할당량 관리</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* 안내 */}
      <div className="content-card" style={{ background: '#f8f9fa' }}>
        <h3>💡 플랫폼 연동 가이드</h3>
        <ul style={{ lineHeight: '1.8' }}>
          <li><strong>YouTube:</strong> Google OAuth를 통한 자동 인증 (인증정보 메뉴에서 설정)</li>
          <li><strong>TikTok:</strong> 쿠키 기반 인증 (브라우저 개발자 도구에서 추출)</li>
          <li><strong>Instagram/Facebook:</strong> 향후 지원 예정</li>
          <li><strong>새 플랫폼 추가:</strong> Backend API를 통해 관리자가 추가 가능</li>
        </ul>
      </div>
    </div>
  )
}
